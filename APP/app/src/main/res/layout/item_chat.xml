<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Assistant Message Container (Left Aligned) -->
    <LinearLayout
        android:id="@+id/container_assistant"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="horizontal"
        android:gravity="start"
        android:visibility="visible">

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/card_glass"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:gravity="center"
            android:text="AI"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@color/white">

            <TextView
                android:id="@+id/tv_msg_assistant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Hello, how can I help you?"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:maxWidth="240dp"/>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- User Message Container (Right Aligned) -->
    <LinearLayout
        android:id="@+id/container_user"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:orientation="horizontal"
        android:gravity="end"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@color/primary">

            <TextView
                android:id="@+id/tv_msg_user"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Hello!"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:maxWidth="240dp"/>

        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/card_glass"
            android:backgroundTint="@color/gray_200"
            android:textColor="@color/text_dark"
            android:gravity="center"
            android:text="ME"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

</LinearLayout>
