<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_water_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hydration &amp; Water Tracker"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_water_header"
                android:text="Achieve insulin-sensitizing hydration levels."
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

            <!-- Daily Streak Badge -->
            <TextView
                android:id="@+id/tv_water_streak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@color/accent_light"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="🔥 Streak: 0d"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- Circular/Horizontal Progress Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_water_progress_percentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@color/primary"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_water_fraction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 2500 mL"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <ProgressBar
                    android:id="@+id/progress_water"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp"
                    android:progressDrawable="@android:drawable/progress_horizontal"
                    android:progressTint="@color/primary"
                    android:progressBackgroundTint="@color/gray_200"
                    android:max="100"
                    android:progress="0" />

                <TextView
                    android:id="@+id/tv_water_remaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remaining: 2500 mL"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Smart Target Details & Reminders -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SMART CALCULATOR DETAILS"
                    android:textColor="@color/primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_water_formula_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Goal calculated based on Weight (35 mL per kg). Complete profile to personalize adjustments."
                    android:textColor="@color/text_dark"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginBottom="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/gray_200"
                    android:layout_marginBottom="12dp" />

                <!-- Reminders Switch -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_reminder_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Smart Hydration Reminders"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tv_reminder_label"
                        android:text="Periodic reminders from 8:00 AM to 8:00 PM"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp" />

                    <Switch
                        android:id="@+id/switch_reminders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true" />

                </RelativeLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Fast Intake Logging Buttons -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOG WATER INTAKE"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_add_250"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="46dp"
                android:text="+250 ml"
                android:textSize="11sp"
                android:layout_marginEnd="4dp"
                android:backgroundTint="@color/primary_light"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btn_add_500"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="46dp"
                android:text="+500 ml"
                android:textSize="11sp"
                android:layout_marginHorizontal="2dp"
                android:backgroundTint="@color/primary_light"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btn_add_750"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="46dp"
                android:text="+750 ml"
                android:textSize="11sp"
                android:layout_marginHorizontal="2dp"
                android:backgroundTint="@color/primary_light"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btn_add_custom"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="46dp"
                android:text="+Custom"
                android:textSize="11sp"
                android:layout_marginStart="4dp"
                android:backgroundTint="@color/primary_dark"
                android:textColor="@color/white" />

        </LinearLayout>

        <!-- Intake History List -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TODAY'S INTAKE HISTORY"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:id="@+id/layout_water_logs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
