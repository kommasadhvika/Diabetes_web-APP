<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tv_calc_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clinical Health Calculators"
            android:textColor="@color/text_dark"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:text="Compute glycemic limits and target metabolic expenditures."
            android:textColor="@color/text_muted"
            android:textSize="12sp" />

        <!-- Card: Input Parameters -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_card_light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BIOMETRIC PARAMETERS"
                    android:textColor="@color/primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Row 1: Weight & Height -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Weight (kg)"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <EditText
                            android:id="@+id/et_calc_weight"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_input_border"
                            android:inputType="numberDecimal"
                            android:paddingHorizontal="12dp"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp"
                            android:text="70"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Height (cm)"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <EditText
                            android:id="@+id/et_calc_height"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_input_border"
                            android:inputType="numberDecimal"
                            android:paddingHorizontal="12dp"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp"
                            android:text="170"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Row 2: Age & Gender -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Age (years)"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <EditText
                            android:id="@+id/et_calc_age"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_input_border"
                            android:inputType="number"
                            android:paddingHorizontal="12dp"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp"
                            android:text="35"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gender"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <Spinner
                            android:id="@+id/spinner_calc_gender"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_input_border"
                            android:paddingHorizontal="12dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Row 3: Activity Level -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Physical Activity Level"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <Spinner
                    android:id="@+id/spinner_calc_activity"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_input_border"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="12dp" />

                <!-- Row 4: Average Blood Glucose -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Average Blood Glucose (mg/dL)"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/et_calc_glucose"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_input_border"
                    android:inputType="numberDecimal"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:text="120" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- BMI Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card_light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BODY MASS INDEX (BMI)"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_calc_bmi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24.2"
                    android:textColor="@color/text_dark"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_calc_bmi_cat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Normal Weight"
                    android:textColor="@color/risk_low"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Maintaining a BMI within the 18.5–24.9 window markedly boosts insulin sensitivity and reduces tissue resistance."
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- BMR Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card_light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BASAL METABOLIC RATE (BMR)"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_calc_bmr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1650 kcal"
                    android:textColor="@color/text_dark"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="kcal / day (rest energy)"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Your body burns this amount of calories daily purely at rest to support vital cellular functions, respiration, and blood flow."
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Estimated HbA1c Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card_light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ESTIMATED HbA1c LEVEL"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_calc_hba1c"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5.8%"
                    android:textColor="@color/text_dark"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_calc_hba1c_cat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prediabetic"
                    android:textColor="@color/risk_medium"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>

                <!-- Linear Progress Risk Indicator -->
                <ProgressBar
                    android:id="@+id/progress_hba1c"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:max="100"
                    android:progress="40"
                    android:progressTint="@color/risk_medium" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="HbA1c represents your average blood glucose concentrations over the past 3 months. Keep HbA1c below 6.5% to reduce microvascular risks."
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Calories & Macro splits -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/bg_card_light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TARGET CALORIC INTAKE &amp; MACROS SPLIT"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_calc_target_calories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1480"
                    android:textColor="@color/primary"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="kcal / day (Weight-Control Deficit)"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Carbs macro progress -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Carbs (40%)"
                        android:textColor="@color/text_dark"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_alignParentStart="true"/>

                    <TextView
                        android:id="@+id/tv_calc_carb_grams"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="148g"
                        android:textColor="@color/risk_medium"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_alignParentEnd="true"/>

                </RelativeLayout>

                <!-- Protein macro progress -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Protein (30%)"
                        android:textColor="@color/text_dark"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_alignParentStart="true"/>

                    <TextView
                        android:id="@+id/tv_calc_protein_grams"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="111g"
                        android:textColor="@color/risk_low"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_alignParentEnd="true"/>

                </RelativeLayout>

                <!-- Fats macro progress -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fats (30%)"
                        android:textColor="@color/text_dark"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_alignParentStart="true"/>

                    <TextView
                        android:id="@+id/tv_calc_fat_grams"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="49g"
                        android:textColor="@android:color/holo_blue_dark"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_alignParentEnd="true"/>

                </RelativeLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
