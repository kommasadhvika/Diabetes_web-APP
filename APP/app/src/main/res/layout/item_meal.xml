<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/bg_card_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Meal Image -->
        <ImageView
            android:id="@+id/iv_meal_image"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_marginBottom="12dp"
            android:contentDescription="Meal Image" />

        <!-- Top Header: Meal Type/Time and Calories -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_meal_type_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BREAKFAST (08:00 AM)"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"/>

            <TextView
                android:id="@+id/tv_meal_calories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="450 kcal"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>

        </RelativeLayout>

        <!-- Meal Title and Glycemic Index Badge -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_meal_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/tv_meal_gi"
                android:layout_marginEnd="8dp"
                android:text="Oatmeal with Almonds"
                android:textColor="@color/text_dark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_meal_gi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@color/gray_200"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="GI: LOW"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- Macros Breakdown -->
        <TextView
            android:id="@+id/tv_meal_macros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CARBS: 45g  •  PROTEIN: 15g  •  FAT: 10g"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- AI Advice Box -->
        <LinearLayout
            android:id="@+id/layout_advice_box"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/gray_200"
            android:padding="10dp">

            <TextView
                android:id="@+id/tv_meal_why"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AI Advice: High-fiber carbs prevent spike."
                android:textColor="@color/text_dark"
                android:textSize="11sp"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
