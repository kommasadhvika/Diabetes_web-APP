<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Top Chat Bot Bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/chat_header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/tv_bot_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DiaPredict AI Clinical Specialist"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_centerVertical="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_bot_status"
                android:text="Online"
                android:textColor="@color/risk_low"
                android:textSize="10sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btn_clear_chat"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="Clear"
                android:textSize="10sp"
                android:backgroundTint="@color/risk_high"
                android:textColor="@color/white"
                android:paddingHorizontal="8dp"/>

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

    <!-- Scrollable Message list -->
    <ScrollView
        android:id="@+id/chat_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/chat_input_panel"
        android:layout_below="@id/chat_header"
        android:fillViewport="true"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/layout_chat_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <!-- Bottom Input Panel -->
    <LinearLayout
        android:id="@+id/chat_input_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/white"
        android:layout_alignParentBottom="true"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/et_chat_input"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:hint="Ask about diet, glucose spikes..."
            android:inputType="textShortMessage"
            android:padding="12dp"
            android:background="@drawable/card_glass"
            android:textColor="@color/text_dark"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_chat_send"
            android:layout_width="64dp"
            android:layout_height="48dp"
            android:text="Send"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:padding="0dp"
            android:textSize="12sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_centerInParent="true"
        android:visibility="gone"
        android:indeterminateTint="@color/primary"/>

</RelativeLayout>
