{
  "name": "diapredict-mobile-automation",
  "version": "1.0.0",
  "description": "Enterprise Appium E2E Automation Framework for Android Application",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test": "mocha tests/**/*.test.js --timeout 120000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=index,html=true,json=true",
    "test:auth": "mocha tests/auth.test.js --timeout 120000",
    "test:form": "mocha tests/form.test.js --timeout 120000",
    "test:gestures": "mocha tests/gestures.test.js --timeout 120000",
    "driver:install": "appium driver install uiautomator2"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "chai": "^4.4.1",
    "dotenv": "^16.4.5",
    "mocha": "^10.3.0",
    "mochawesome": "^7.1.3",
    "mochawesome-report-generator": "^6.2.0",
    "webdriverio": "^8.32.4"
  }
}
